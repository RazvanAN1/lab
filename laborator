int isBSTUtil(Node* root, int min, int max) {
    if (root == NULL) return 1;

    if (root->val <= min || root->val >= max)
        return 0;

    return isBSTUtil(root->left, min, root->val) &&
           isBSTUtil(root->right, root->val, max);
}

int isBST(Node* root) {
    return isBSTUtil(root, INT_MIN, INT_MAX);
}
