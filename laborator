int findLevel(Node* root, int val, int level) {
    if (root == NULL) return 0;

    if (root->val == val) return level;

    int l = findLevel(root->left, val, level + 1);
    if (l) return l;

    return findLevel(root->right, val, level + 1);
}

int isSibling(Node* root, int a, int b) {
    if (root == NULL) return 0;

    if (root->left && root->right) {
        if ((root->left->val == a && root->right->val == b) ||
            (root->left->val == b && root->right->val == a))
            return 1;
    }

    return isSibling(root->left, a, b) ||
           isSibling(root->right, a, b);
}

int areCousins(Node* root, int a, int b) {
    return (findLevel(root, a, 1) == findLevel(root, b, 1)) &&
           !isSibling(root, a, b);
}
